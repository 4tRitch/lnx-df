#!/usr/bin/env python3
import json
import os
from pathlib import Path

cache_home = Path(os.environ.get("XDG_CACHE_HOME", Path.home() / ".cache"))
history = cache_home / "lnx-df-control-center" / "notifications.jsonl"
history.parent.mkdir(parents=True, exist_ok=True)

hints = {
    key.removeprefix("SWAYNC_HINT_").lower(): value
    for key, value in os.environ.items()
    if key.startswith("SWAYNC_HINT_") and value
}

item = {
    "id": os.environ.get("SWAYNC_ID", ""),
    "app": os.environ.get("SWAYNC_APP_NAME", ""),
    "summary": os.environ.get("SWAYNC_SUMMARY", ""),
    "body": os.environ.get("SWAYNC_BODY", ""),
    "urgency": os.environ.get("SWAYNC_URGENCY", ""),
    "time": os.environ.get("SWAYNC_TIME", ""),
    "desktop_entry": os.environ.get("SWAYNC_DESKTOP_ENTRY", ""),
    "category": os.environ.get("SWAYNC_CATEGORY", ""),
    "hints": hints,
}

try:
    lines = history.read_text(errors="ignore").splitlines()[-79:]
except Exception:
    lines = []
lines.append(json.dumps(item, ensure_ascii=False))
history.write_text("\n".join(lines) + "\n")
