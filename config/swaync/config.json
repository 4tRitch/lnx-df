{
  "$schema": "/etc/xdg/swaync/configSchema.json",

  "positionX": "right",
  "positionY": "top",

  "layer": "overlay",
  "control-center-layer": "overlay",
  "layer-shell": true,

  "cssPriority": "user",

  "control-center-width": 380,
  "control-center-height": 620,
  "notification-window-width": 380,

  "notification-icon-size": 36,
  "notification-body-image-height": 120,
  "notification-body-image-width": 190,

  "timeout": 6,
  "timeout-low": 4,
  "timeout-critical": 0,

  "fit-to-screen": true,
  "keyboard-shortcuts": true,
  "image-visibility": "when-available",
  "transition-time": 160,

  "hide-on-clear": false,
  "hide-on-action": true,
  "script-fail-notify": true,

  "widgets": [
    "title",
    "dnd",
    "notifications"
  ],

  "widget-config": {
    "title": {
      "text": "Notifications",
      "clear-all-button": true,
      "button-text": "Clear"
    },
    "dnd": {
      "text": "Do Not Disturb"
    }
  }
}
