{
  "$schema": "https://opencode.ai/config.json",

  "plugin": [
    "oh-my-openagent@latest"
  ],

  "provider": {
    "llamacpp": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "llama.cpp",
      "options": {
        "baseURL": "http://127.0.0.1:8080/v1",
        "apiKey": "local"
      },
      "models": {
        "qwen3.5-4b": {
          "name": "qwen3.5-4b_q8",
          "limit": {
            "context": 32768,
            "output": 8192
          }
        },
        "qwen3.5-9b-vlm": {
          "name": "qwen3.5-9b-vlm",
          "limit": {
            "context": 32768,
            "output": 8192
          }
        }
      }
    }
  },

  "mcp": {
    "blender": {
      "type": "local",
      "command": ["uvx", "blender-mcp"],
      "enabled": true,
      "environment": {
        "BLENDER_HOST": "localhost",
        "BLENDER_PORT": "9876"
      }
    }
  }
}
